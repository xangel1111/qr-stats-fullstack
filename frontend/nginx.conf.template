server {
    # ${PORT} is substituted at container start (defaults to 80 locally,
    # set dynamically by the platform e.g. Railway).
    listen ${PORT};
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # SPA fallback: unknown routes serve index.html.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
