# HTTP
PORT=8080

# PostgreSQL connection string (sslmode=disable for local/dev)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/qrdb?sslmode=disable
AUTO_MIGRATE=true

# JWT (HS256). Change the secret in every real environment.
JWT_SECRET=super-secret-change-me
JWT_EXPIRY=1h

# Node statistics service
NODE_STATS_URL=http://localhost:3000
NODE_TIMEOUT=5s

# Demo credentials for POST /auth/login
AUTH_USERNAME=demo
AUTH_PASSWORD=demo123
