# Shared HS256 secret used by BOTH APIs (Go issues/validates, Node validates).
JWT_SECRET=super-secret-change-me

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qrdb

# Demo credentials for POST /auth/login (Go API)
AUTH_USERNAME=demo
AUTH_PASSWORD=demo123

# Logging level for the Node API
LOG_LEVEL=info
